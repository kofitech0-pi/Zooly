<%- include('partials/header.ejs') %>
<%- include('partials/navbar.ejs', { page: 'turmas' }) %>
<%- include('partials/topbar.ejs') %>

<div class="page-content aluno-editar-page">
  <a href="/turmas/<%= aluno.turma_id %>/alunos" class="btn-back">
    <i data-lucide="arrow-left"></i>
    <span>Voltar para Alunos</span>
  </a>

  <div class="page-header">
    <div>
      <h1 class="page-title">Editar Aluno</h1>
      <p class="page-subtitle">
        Atualize os dados cadastrais do aluno selecionado.
      </p>
    </div>
  </div>

  <div class="form-card aluno-editar-card">
    <form action="/alunos/alterar" method="POST">
      <input type="hidden" name="id" value="<%= aluno.id %>">

      <div class="edit-card-title">
        <i data-lucide="user-round"></i>
        <span>Dados do Aluno</span>
      </div>

      <div class="form-group">
        <label>Nome do Aluno</label>
        <input type="text" name="nome" value="<%= aluno.nome %>" class="form-input" placeholder="Nome completo do aluno" required>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label>Idade</label>
          <input type="number" name="idade" value="<%= aluno.idade %>" class="form-input" min="1" max="20" required>
        </div>

        <div class="form-group">
          <label>RA do Aluno</label>
          <input type="text" name="ra" value="<%= aluno.ra %>" class="form-input" placeholder="Ex: 2024001" required>
        </div>
      </div>


      <div class="form-group">
        <label>Imagem do Aluno</label>
        <div class="imgs-grid-modal">
          <% const imgAluno = aluno.imagem || 'cobra-vetor.png'; %>
          <label class="img-option-circulo">
            <input type="radio" name="imagem" value="cobra-vetor.png" <%= imgAluno === 'cobra-vetor.png' ? 'checked' : '' %>>
            <span class="circulo-img"><img src="/img/cobra-vetor.png" alt="Cobra"></span>
          </label>
          <label class="img-option-circulo">
            <input type="radio" name="imagem" value="lagarto-vetor.png" <%= imgAluno === 'lagarto-vetor.png' ? 'checked' : '' %>>
            <span class="circulo-img"><img src="/img/lagarto-vetor.png" alt="Lagarto"></span>
          </label>
          <label class="img-option-circulo">
            <input type="radio" name="imagem" value="papagaio-vetor.png" <%= imgAluno === 'papagaio-vetor.png' ? 'checked' : '' %>>
            <span class="circulo-img"><img src="/img/papagaio-vetor.png" alt="Papagaio"></span>
          </label>
          <label class="img-option-circulo">
            <input type="radio" name="imagem" value="sarue-vetor.png" <%= imgAluno === 'sarue-vetor.png' ? 'checked' : '' %>>
            <span class="circulo-img"><img src="/img/sarue-vetor.png" alt="Saruê"></span>
          </label>
        </div>
      </div>

      <div class="edit-card-title section-title-sm">
        <i data-lucide="users-round"></i>
        <span>Dados do Responsável</span>
      </div>

      <div class="form-group">
        <label>Nome do Responsável</label>
        <input type="text" name="nome_responsavel" value="<%= aluno.nome_responsavel %>" class="form-input" placeholder="Nome completo do responsável" required>
      </div>

      <div class="form-group">
        <label>Email do Responsável</label>
        <input type="email" name="email_responsavel" value="<%= aluno.email_responsavel %>" class="form-input" placeholder="responsavel@email.com" required>
      </div>

      <div class="form-group">
        <label>Turma</label>
        <select name="turma_id" class="form-input" required>
          <% turmas.forEach(t => { %>
          <option value="<%= t.id %>" <%= t.id === aluno.turma_id ? 'selected' : '' %>>
            <%= t.nome %>
          </option>
          <% }) %>
        </select>
      </div>

      <div class="form-actions">
        <a href="/turmas/<%= aluno.turma_id %>/alunos" class="btn-cancel">
          Cancelar
        </a>

        <button type="submit" class="btn-primary">
          <i data-lucide="save"></i>
          <span>Salvar Alterações</span>
        </button>
      </div>
    </form>
  </div>
</div>

<%- include('partials/footer.ejs') %>