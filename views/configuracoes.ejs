<%- include('partials/header.ejs') %>
<%- include('partials/navbar.ejs', { page: 'configuracoes' }) %>
<%- include('partials/topbar.ejs') %>

<div class="page-content configuracoes-page">
  <h1 class="page-title">Configurações</h1>

  <div class="config-layout">
    <div class="config-left">

      <div class="config-card">
        <h2 class="config-card-title">
          <i data-lucide="user-round"></i>
          <span>Dados do Professor</span>
        </h2>

        <div class="config-form-grid two-cols">
          <div class="form-group">
            <label>Nome Completo</label>
            <input type="text" class="form-input" value="Helena Ferreira">
          </div>

          <div class="form-group">
            <label>E-mail</label>
            <input type="email" class="form-input" value="helena.ferreira@zooly.edu.br">
          </div>
        </div>

        <button type="button" class="btn-config-light">
          Solicitar para Alterar a senha
        </button>
      </div>

      <div class="config-card">
        <h2 class="config-card-title">
          <i data-lucide="graduation-cap"></i>
          <span>Dados da Escola</span>
        </h2>

        <div class="form-group">
          <label>Nome da Escola</label>
          <input type="text" class="form-input" value="Colégio Luminoso Primário">
        </div>

        <div class="config-form-grid two-cols">
          <div class="form-group">
            <label>Código da Escola</label>
            <input type="text" class="form-input" value="EDU-99238">
          </div>

          <div class="form-group">
            <label>Telefone</label>
            <input type="text" class="form-input" value="+55 (11) 98877-6655">
          </div>
        </div>

        <div class="form-group">
          <label>Endereço</label>
          <input type="text" class="form-input" value="Av. das Flores, 1234 - Jardim Botânico, São Paulo - SP">
        </div>

        <div class="form-group">
          <label>E-mail Institucional</label>
          <input type="email" class="form-input" value="contato@colegioluminoso.com.br">
        </div>
      </div>

    </div>

    <div class="config-right">

      <div class="config-card profile-card">
        <div class="profile-photo-wrap">
          <img src="https://i.pravatar.cc/180?img=47" alt="Foto de perfil">
          <button type="button" class="profile-edit">
            <i data-lucide="pencil"></i>
          </button>
        </div>

        <h2>Foto de perfil</h2>
        <p>JPG ou PNG. Tamanho máximo de 2MB.</p>

        <button type="button" class="btn-outline-config">
          Carregar nova foto
        </button>
      </div>

      <div class="config-card notifications-card">
        <h2 class="config-card-title">
          <i data-lucide="bell"></i>
          <span>Notificações</span>
        </h2>

        <div class="notification-item">
          <div>
            <strong>Aluno concluiu atividade</strong>
            <p>Receba um aviso imediato.</p>
          </div>

          <label class="switch">
            <input type="checkbox">
            <span></span>
          </label>
        </div>

        <div class="notification-item">
          <div>
            <strong>Atividades próximas do prazo</strong>
            <p>Lembretes de prazos finais.</p>
          </div>

          <label class="switch">
            <input type="checkbox">
            <span></span>
          </label>
        </div>
      </div>
    </div>
    <div class="config-actions">
      <button type="button" class="btn-discard">Descartar Alterações</button>
      <button type="button" class="btn-save-config">Salvar Configurações</button>
    </div>
  </div>
</div>

<%- include('partials/footer.ejs') %>