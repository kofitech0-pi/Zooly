<div class="layout">
    <aside class="navbar">
        <div class="logo">
            <img src="/img/logo.png" alt="Zooly Education">
        </div>

        <nav class="nav-menu">
            <a href="/" class="nav-item <%= typeof page !== 'undefined' && page === 'home' ? 'active' : '' %>">
                <i data-lucide="home"></i>
                <span>Home</span>
            </a>

            <a href="/turmas" class="nav-item <%= typeof page !== 'undefined' && page === 'turmas' ? 'active' : '' %>">
                <i data-lucide="users"></i>
                <span>Turmas</span>
            </a>

            <a href="/atividades" class="nav-item <%= typeof page !== 'undefined' && page === 'atividades' ? 'active' : '' %>">
                <i data-lucide="clipboard-list"></i>
                <span>Atividades</span>
            </a>

            <a href="/desempenho" class="nav-item <%= typeof page !== 'undefined' && page === 'desempenho' ? 'active' : '' %>">
                <i data-lucide="bar-chart-3"></i>
                <span>Desempenho</span>
            </a>
        </nav>

        <div class="nav-bottom">
            <a href="/configuracoes" class="nav-item <%= typeof page !== 'undefined' && page === 'configuracoes' ? 'active' : '' %>">
                <i data-lucide="settings"></i>
                <span>Configurações</span>
            </a>

            <form action="/logout" method="POST">
              <button type="button" class="nav-item btn-sair" onclick="abrirModal('modalSair')">
    <i data-lucide="log-out"></i>
    <span>Sair</span>
</button>
            </form>
        </div>
    </aside>

    <main class="main-content">