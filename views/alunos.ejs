<%- include('partials/header.ejs') %>
<%- include('partials/navbar.ejs', { page: 'turmas' }) %>
<%- include('partials/topbar.ejs') %>

<div class="page-content alunos-page">
  <a href="/turmas" class="btn-back">
    <i data-lucide="arrow-left"></i>
    <span>Voltar para Turmas</span>
  </a>

  <div class="turma-header">
    <div class="turma-header-info">
      <h1 class="page-title"><%= turma.nome %></h1>
      <p class="page-subtitle">Gestão de alunos e progresso de missões acadêmicas.</p>
    </div>

    <button class="btn-primary" onclick="abrirModal('modalCadastro')">
      <i data-lucide="plus"></i>
      <span>Novo Aluno</span>
    </button>
  </div>

  <!-- CARDS DE ESTATÍSTICAS -->
  <div class="stats-row">
    <div class="stat-card-mini stat-alunos">
      <div class="stat-label">ALUNOS</div>

      <div class="stat-info">
        <span class="stat-number"><%= alunos.length %></span>
        <span class="stat-text">Matriculados</span>
      </div>
    </div>

    <div class="stat-card-mini">
      <div class="stat-label">MISSÕES</div>

      <div class="stat-info">
        <span class="stat-number">10</span>
        <span class="stat-text">Ativas</span>
      </div>

      <div class="stat-meta">50% Meta</div>
    </div>

    <div class="stat-card-mini">
      <div class="stat-label">CONCLUÍDAS</div>

      <div class="stat-info">
        <span class="stat-number">5</span>
        <span class="stat-text">Finalizadas</span>
      </div>

      <div class="stat-meta">Bom desempenho geral</div>
    </div>
  </div>

  <!-- TABELA DE ALUNOS -->
  <div class="table-card">
    <h2>Lista de Alunos</h2>

    <% if (alunos && alunos.length > 0) { %>
    <table class="data-table">
      <thead>
        <tr>
          <th>ALUNO</th>
          <th>STATUS</th>
          <th>PROGRESSO</th>
          <th>ÚLTIMO ACESSO</th>
          <th>AÇÕES</th>
        </tr>
      </thead>

      <tbody>
        <% alunos.forEach(aluno => { %>
        <tr>
          <td class="aluno-info">
            <div class="aluno-lista-info">
              <div class="aluno-foto">
               <img src="/img/<%= aluno.imagem || 'cobra-botao.png' %>" alt="Imagem do aluno <%= aluno.nome %>">
              </div>
              <div>
                <strong><%= aluno.nome %></strong><br>
                <small class="aluno-email"><%= aluno.email_responsavel %></small>
              </div>
            </div>
          </td>

          <td>
            <span class="status-badge status-ativo">ATIVO</span>
          </td>

          <td>
            <div class="progress-cell">
              <div class="progress-bar-small">
                <div class="progress" style="width: <%= aluno.progresso || 85 %>%;"></div>
              </div>

              <span class="progress-value"><%= aluno.progresso || 85 %>%</span>
            </div>
          </td>

          <td class="ultimo-acesso">
            <%= aluno.ultimo_acesso || 'Hoje, 10:45' %>
          </td>

          <td>
            <div class="actions-cell">
              <a href="/alunos/editar/<%= aluno.id %>" class="btn-table-action" title="Editar">
                <i data-lucide="pencil"></i>
              </a>

              <a href="#" data-aluno-id="<%= aluno.id %>" data-turma-id="<%= turma.id %>" onclick="confirmarExcluirAluno(this.dataset.alunoId, this.dataset.turmaId); return false;" class="btn-table-action danger" title="Excluir">
                <i data-lucide="trash-2"></i>
              </a>

            </div>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>

    <div class="table-footer">
      EXIBINDO <%= alunos.length %> DE <%= alunos.length %> ALUNOS
    </div>
    <% } else { %>
    <div class="empty-state">
      <p>Nenhum aluno cadastrado nesta turma.</p>

      <button class="btn-primary" onclick="abrirModal('modalCadastro')">
        <i data-lucide="plus"></i>
        <span>Adicionar Primeiro Aluno</span>
      </button>
    </div>
    <% } %>
  </div>
</div>

<!-- MODAL DE CADASTRO DE ALUNO -->
<div id="modalCadastro" class="modal-overlay" style="display: none;">
  <div class="modal">
    <h2>Novo Aluno</h2>
    <p class="modal-subtitle">Preencha os dados do aluno para matriculá-lo na turma.</p>

    <form action="/alunos/cadastrar" method="POST">
      <input type="hidden" name="turma_id" value="<%= turma.id %>">

      <div class="form-group">
        <label>Nome do Aluno</label>
        <input type="text" name="nome" placeholder="Ex: Sarah do Nascimento" class="form-input" required>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label>Idade</label>
          <input type="number" name="idade" placeholder="Ex: 8" class="form-input" min="1" max="20" required>
        </div>

        <div class="form-group">
          <label>RA do Aluno</label>
          <input type="text" name="ra" placeholder="Ex: 154542026" class="form-input" required>
        </div>
      </div>


      <div class="form-group">
        <label>Imagem do Aluno</label>
        <div class="imgs-grid-modal">
          <label class="img-option-circulo">
            <input type="radio" name="imagem" value="cobra-vetor.png" checked>
            <span class="circulo-img"><img src="/img/cobra-vetor.png" alt="Cobra"></span>
          </label>
          <label class="img-option-circulo">
            <input type="radio" name="imagem" value="lagarto-vetor.png">
            <span class="circulo-img"><img src="/img/lagarto-vetor.png" alt="Lagarto"></span>
          </label>
          <label class="img-option-circulo">
            <input type="radio" name="imagem" value="papagaio-vetor.png">
            <span class="circulo-img"><img src="/img/papagaio-vetor.png" alt="Papagaio"></span>
          </label>
          <label class="img-option-circulo">
            <input type="radio" name="imagem" value="sarue-vetor.png">
            <span class="circulo-img"><img src="/img/sarue-vetor.png" alt="Saruê"></span>
          </label>
        </div>
      </div>

      <div class="form-group">
        <label>Nome do Responsável</label>
        <input type="text" name="nome_responsavel" placeholder="Ex: Thais do Nascimento" class="form-input" required>
      </div>

      <div class="form-group">
        <label>Email do Responsável</label>
        <input type="email" name="email_responsavel" placeholder="Ex: thais@gmail.com" class="form-input" required>
      </div>

      <div class="modal-buttons">
        <button type="button" class="btn-cancel" onclick="fecharModal('modalCadastro')">
          Cancelar
        </button>

        <button type="submit" class="btn-primary">
          <i data-lucide="check"></i>
          <span>Cadastrar Aluno</span>
        </button>
      </div>
    </form>
  </div>
</div>

<script>
  function confirmarExcluirAluno(alunoId, turmaId) {
    if (confirm('Deseja realmente excluir este aluno?')) {
      const form = document.createElement('form');
      form.method = 'POST';
      form.action = '/alunos/excluir/' + alunoId + '/' + turmaId;
      document.body.appendChild(form);
      form.submit();
    }
  }
</script>

<%- include('partials/footer.ejs') %>