<%- include('partials/header.ejs') %>
<%- include('partials/navbar.ejs', { page: 'atividades' }) %>
<%- include('partials/topbar.ejs') %>

<div class="page-content nova-atividade-page">

  <div class="na-topbar">
    <a href="/atividades" class="btn-back">
      <i data-lucide="arrow-left"></i>
      <span>Editar Atividade</span>
    </a>
  </div>

  <form action="/atividades/alterar" method="POST" id="formAtividade" onsubmit="prepararEnvioAtividade()">
    <input type="hidden" name="id" value="<%= atividade.id %>">

    <div class="na-layout">

      <div class="na-col-left">

        <div class="na-card">
          <div class="na-card-title">
            <i data-lucide="clipboard-list"></i>
            <span>Informações Gerais</span>
          </div>

          <div class="form-group">
            <label class="na-label">NOME DA ATIVIDADE</label>
            <input type="text" name="nome" class="na-input" value="<%= atividade.nome || '' %>" required>
          </div>

          <div class="na-row3">
            <div class="form-group">
              <label class="na-label">SÉRIE / ANO</label>
              <select name="serie_ano" class="na-input">
                <option value="1º Ano Fundamental I" <%= atividade.serie_ano === '1º Ano Fundamental I' ? 'selected' : '' %>>1º Ano Fundamental I</option>
                <option value="2º Ano Fundamental I" <%= atividade.serie_ano === '2º Ano Fundamental I' ? 'selected' : '' %>>2º Ano Fundamental I</option>
                <option value="3º Ano Fundamental I" <%= atividade.serie_ano === '3º Ano Fundamental I' ? 'selected' : '' %>>3º Ano Fundamental I</option>
                <option value="4º Ano Fundamental I" <%= atividade.serie_ano === '4º Ano Fundamental I' ? 'selected' : '' %>>4º Ano Fundamental I</option>
                <option value="5º Ano Fundamental I" <%= atividade.serie_ano === '5º Ano Fundamental I' ? 'selected' : '' %>>5º Ano Fundamental I</option>
              </select>
            </div>

            <div class="form-group">
              <label class="na-label">TURMA</label>
              <select name="turma_id" class="na-input" required>
                <option value="">Selecione...</option>
                <% turmas.forEach(t => { %>
                <option value="<%= t.id %>" <%= t.id === atividade.turma_id ? 'selected' : '' %>>
                  <%= t.nome %>
                </option>
                <% }) %>
              </select>
            </div>

            <div class="form-group">
              <label class="na-label">DURAÇÃO ESTIMADA</label>
              <div class="na-input-icon">
                <i data-lucide="clock"></i>
                <input type="text" name="duracao" class="na-input-inner" value="<%= atividade.duracao || '45 min' %>">
              </div>
            </div>
          </div>

          <div class="na-row3" style="margin-top: 18px;">
            <div class="form-group">
              <label class="na-label">STATUS</label>
              <select name="status" class="na-input">
                <option value="Agendada" <%= atividade.status === 'Agendada' ? 'selected' : '' %>>Agendada</option>
                <option value="Em Andamento" <%= atividade.status === 'Em Andamento' || atividade.status === 'Em andamento' ? 'selected' : '' %>>Em Andamento</option>
                <option value="Concluída" <%= atividade.status === 'Concluída' ? 'selected' : '' %>>Concluída</option>
              </select>
            </div>

            <div class="form-group">
              <label class="na-label">PONTOS</label>
              <input type="number" name="pontos_total" id="pontosTotal" class="na-input" value="<%= atividade.pontos_total || 0 %>" min="0">
            </div>
          </div>
        </div>

        <!-- HISTÓRIA DA ATIVIDADE -->
        <div class="na-card">
          <div class="na-card-title">
            <i data-lucide="book-open"></i>
            <span>História da Atividade</span>
          </div>

          <div class="tipo-historia-opcoes">
            <label class="tipo-historia-card">
              <input type="radio" name="tipo_historia" value="biblioteca" <%= atividade.historia_id ? 'checked' : '' %> onchange="alternarTipoHistoria()">
              <span>Usar história da biblioteca</span>
            </label>

            <label class="tipo-historia-card">
              <input type="radio" name="tipo_historia" value="propria" <%= !atividade.historia_id ? 'checked' : '' %> onchange="alternarTipoHistoria()">
              <span>Escrever minha própria história</span>
            </label>
          </div>

          <div id="areaHistoriaBiblioteca">
            <div class="form-group">
              <label class="na-label">ESCOLHER HISTÓRIA DA BIBLIOTECA</label>

              <select name="historia_id" class="na-input" onchange="preencherHistoriaSelecionada(this)">
                <option value="">Selecione uma história...</option>

                <% if (historias && historias.length > 0) { %>
                <% historias.forEach(h => { %>
                <option value="<%= h.id %>" <%= atividade.historia_id === h.id ? 'selected' : '' %>>
                  <%= h.titulo %> - <%= h.nivel_leitura %>
                </option>
                <% }) %>
                <% } %>
              </select>
            </div>

            <div class="historia-fixa-box" id="historiaFixaBox">
              <% if (atividade.historia) { %>
              <h4>História da atividade</h4>
              <div class="historia-texto-fixo"><%= atividade.historia %></div>
              <% } else { %>
              <p class="historia-vazia">Selecione uma história para visualizar o texto.</p>
              <% } %>
            </div>
          </div>

          <div id="areaHistoriaPropria" style="display: none;">
            <div class="form-group">
              <label class="na-label">ESCREVA SUA HISTÓRIA</label>

              <textarea name="historia_propria" class="na-textarea" rows="8" placeholder="Digite aqui a história que será usada na atividade..."><%= !atividade.historia_id ? atividade.historia || '' : '' %></textarea>
            </div>
          </div>

          <input type="hidden" name="historia" id="historiaHidden" value="<%= atividade.historia || '' %>">
        </div>

        <!-- FONEMA TRABALHADO -->
        <div class="na-card">
          <div class="na-card-title">
            <i data-lucide="volume-2"></i>
            <span>Fonema trabalhado</span>
          </div>

          <p class="na-card-sub">
            Escolha o som que será trabalhado nesta atividade.
          </p>

          <div class="fonema-grid">
            <% ['S', 'R', 'L', 'M', 'P', 'F', 'V', 'CH', 'LH', 'NH'].forEach(f => { %>
            <label class="fonema-btn">
              <input type="radio" name="fonema" value="<%= f %>" <%= atividade.fonema === f ? 'checked' : '' %> required>
              <span><%= f %></span>
            </label>
            <% }) %>
          </div>
        </div>

        <!-- QUESTÕES DA ATIVIDADE -->
        <div class="na-card">
          <div class="na-card-header-row">
            <div class="na-card-title">
              <i data-lucide="sparkles"></i>
              <span>Questões da Atividade</span>
            </div>

            <div class="na-card-actions">
              <button type="button" class="btn-nova-questao" onclick="adicionarQuestao()">
                <i data-lucide="plus"></i>
                <span>Nova questão</span>
              </button>

              <button type="button" class="btn-gerar-ia">
                <i data-lucide="wand-sparkles"></i>
                <span>Gerar com IA</span>
              </button>
            </div>
          </div>

          <div class="questoes-header">
            <span>ORDEM</span>
            <span>TIPO</span>
            <span>PONTOS</span>
            <span>ENUNCIADO</span>
            <span>TAGS</span>
            <span>AÇÕES</span>
          </div>

          <div id="questoesList"></div>

          <button type="button" class="btn-add-questao" onclick="adicionarQuestao()">
            <i data-lucide="plus"></i>
            <span>Adicionar mais uma questão</span>
          </button>
        </div>

        <div class="na-card">
          <div class="na-card-title">
            <i data-lucide="trophy"></i>
            <span>Recompensa</span>
          </div>

          <div class="recompensa-row">
            <span class="recompensa-label">Total da Atividade:</span>
            <span class="recompensa-pts" id="recompensaPts">
              <%= atividade.pontos_total || 0 %> pts
            </span>
          </div>
        </div>

      </div>

      <div class="na-col-right">

        <div class="na-card">
          <div class="na-card-title">
            <i data-lucide="mouse-pointer-click"></i>
            <span>Como o aluno irá interagir?</span>
          </div>

          <p class="na-card-sub">
            Selecione as formas de interação que serão utilizadas.
          </p>

          <div class="interacao-grid">
            <label class="interacao-btn <%= atividade.interacao_ler ? 'active' : '' %>" id="lbl-ler">
              <input type="checkbox" name="interacao_ler" <%= atividade.interacao_ler ? 'checked' : '' %> onchange="toggleInteracao(this, 'lbl-ler')">
              <i data-lucide="book-open"></i>
              <span>Ler</span>
            </label>

            <label class="interacao-btn <%= atividade.interacao_ouvir ? 'active' : '' %>" id="lbl-ouvir">
              <input type="checkbox" name="interacao_ouvir" <%= atividade.interacao_ouvir ? 'checked' : '' %> onchange="toggleInteracao(this, 'lbl-ouvir')">
              <i data-lucide="headphones"></i>
              <span>Ouvir</span>
            </label>

            <label class="interacao-btn <%= atividade.interacao_falar ? 'active' : '' %>" id="lbl-falar">
              <input type="checkbox" name="interacao_falar" <%= atividade.interacao_falar ? 'checked' : '' %> onchange="toggleInteracao(this, 'lbl-falar')">
              <i data-lucide="mic"></i>
              <span>Falar</span>
            </label>

            <label class="interacao-btn <%= atividade.interacao_escrever ? 'active' : '' %>" id="lbl-escrever">
              <input type="checkbox" name="interacao_escrever" <%= atividade.interacao_escrever ? 'checked' : '' %> onchange="toggleInteracao(this, 'lbl-escrever')">
              <i data-lucide="pencil-line"></i>
              <span>Escrever</span>
            </label>
          </div>
        </div>

        <div class="na-card">
          <div class="na-card-title">
            <i data-lucide="target"></i>
            <span>Missão do Aluno</span>
          </div>

          <p class="na-card-sub">O aluno irá:</p>

          <div class="missao-grid">
            <label class="missao-item <%= atividade.missao_ler_texto ? 'active' : '' %>" id="lbl-m1">
              <input type="checkbox" name="missao_ler_texto" <%= atividade.missao_ler_texto ? 'checked' : '' %> onchange="toggleMissao(this, 'lbl-m1')">
              <span class="missao-check"><i data-lucide="check"></i></span>
              <span>Ler um texto</span>
            </label>

            <label class="missao-item <%= atividade.missao_completar ? 'active' : '' %>" id="lbl-m2">
              <input type="checkbox" name="missao_completar" <%= atividade.missao_completar ? 'checked' : '' %> onchange="toggleMissao(this, 'lbl-m2')">
              <span class="missao-check"><i data-lucide="check"></i></span>
              <span>Completar palavras</span>
            </label>

            <label class="missao-item <%= atividade.missao_escutar ? 'active' : '' %>" id="lbl-m3">
              <input type="checkbox" name="missao_escutar" <%= atividade.missao_escutar ? 'checked' : '' %> onchange="toggleMissao(this, 'lbl-m3')">
              <span class="missao-check"><i data-lucide="check"></i></span>
              <span>Escutar e escrever</span>
            </label>

            <label class="missao-item <%= atividade.missao_identificar ? 'active' : '' %>" id="lbl-m4">
              <input type="checkbox" name="missao_identificar" <%= atividade.missao_identificar ? 'checked' : '' %> onchange="toggleMissao(this, 'lbl-m4')">
              <span class="missao-check"><i data-lucide="check"></i></span>
              <span>Identificar sons</span>
            </label>

            <label class="missao-item <%= atividade.missao_responder ? 'active' : '' %>" id="lbl-m5">
              <input type="checkbox" name="missao_responder" <%= atividade.missao_responder ? 'checked' : '' %> onchange="toggleMissao(this, 'lbl-m5')">
              <span class="missao-check"><i data-lucide="check"></i></span>
              <span>Responder perguntas</span>
            </label>
          </div>

          <p class="na-ou">OU DESCREVA MANUALMENTE:</p>

          <textarea name="missao_descricao" class="na-textarea-sm" maxlength="300"><%= atividade.missao_descricao || '' %></textarea>
        </div>

        <div class="na-card">
          <div class="na-card-title">
            <i data-lucide="clipboard-check"></i>
            <span>BNCC</span>
          </div>

          <p class="na-card-sub">HABILIDADES SELECIONADAS</p>

          <div class="bncc-tags" id="bnccTags"></div>

          <div class="bncc-input-row">
            <input type="text" id="bnccInput" class="na-input" placeholder="Ex: EF01LP05" style="font-size:12px; padding:8px 12px;" onkeydown="if(event.key==='Enter'){event.preventDefault();adicionarBNCC();}">

            <button type="button" class="btn-add-bncc" onclick="adicionarBNCC()">
              <i data-lucide="plus"></i>
              <span>Adicionar habilidade</span>
            </button>
          </div>

          <input type="hidden" name="bncc_habilidades" id="bnccHidden" value="<%= atividade.bncc_habilidades || '' %>">
        </div>

        <div class="na-card na-card-dica">
          <p>
            <i data-lucide="lightbulb"></i>
            <strong>Dica:</strong>
            Edite apenas os campos necessários e salve as alterações.
          </p>
        </div>

      </div>
    </div>

    <div class="na-footer">
      <a href="/atividades" class="btn-cancel-na">Cancelar</a>

      <button type="submit" class="btn-salvar-na">
        <i data-lucide="save"></i>
        <span>Salvar Alterações</span>
      </button>
    </div>
  </form>
</div>

<script>
  const historiasFormulario = <%- JSON.stringify((historias || []).map(h => ({
    id: h.id,
    titulo: h.titulo,
    texto: h.texto,
    descricao_curta: h.descricao_curta
  }))) %>;

  function preencherHistoriaSelecionada(select) {
    const historia = historiasFormulario.find(h => String(h.id) === String(select.value));
    const box = document.getElementById('historiaFixaBox');
    const historiaHidden = document.getElementById('historiaHidden');

    if (!historia) {
      box.innerHTML = `<p class="historia-vazia">Selecione uma história para visualizar o texto.</p>`;
      historiaHidden.value = '';
      return;
    }

    box.innerHTML = `
      <h4>${historia.titulo}</h4>
      <p class="historia-descricao">${historia.descricao_curta || ''}</p>
      <div class="historia-texto-fixo">${historia.texto}</div>
    `;

    historiaHidden.value = historia.texto;
  }

  function alternarTipoHistoria() {
    const tipo = document.querySelector('input[name="tipo_historia"]:checked').value;

    const areaBiblioteca = document.getElementById('areaHistoriaBiblioteca');
    const areaPropria = document.getElementById('areaHistoriaPropria');
    const historiaHidden = document.getElementById('historiaHidden');
    const selectHistoria = document.querySelector('select[name="historia_id"]');

    if (tipo === 'biblioteca') {
      areaBiblioteca.style.display = 'block';
      areaPropria.style.display = 'none';

      if (selectHistoria.value) {
        preencherHistoriaSelecionada(selectHistoria);
      }
    } else {
      areaBiblioteca.style.display = 'none';
      areaPropria.style.display = 'block';
      selectHistoria.value = '';
      historiaHidden.value = document.querySelector('textarea[name="historia_propria"]').value;
    }
  }

  function prepararEnvioAtividade() {
    const tipo = document.querySelector('input[name="tipo_historia"]:checked').value;
    const historiaHidden = document.getElementById('historiaHidden');
    const selectHistoria = document.querySelector('select[name="historia_id"]');

    if (tipo === 'propria') {
      const historiaPropria = document.querySelector('textarea[name="historia_propria"]').value;
      historiaHidden.value = historiaPropria;
      selectHistoria.value = '';
    }
  }

  function toggleInteracao(cb, lblId) {
    const lbl = document.getElementById(lblId);
    lbl.classList.toggle('active', cb.checked);
  }

  function toggleMissao(cb, lblId) {
    const lbl = document.getElementById(lblId);
    lbl.classList.toggle('active', cb.checked);
  }

  let questaoCount = 0;
  const tiposQuestao = ['Leitura e interpretação', 'Completar palavra', 'Identificar sons', 'Escrita livre'];

  function adicionarQuestao() {
    questaoCount++;
    const list = document.getElementById('questoesList');

    const div = document.createElement('div');
    div.className = 'questao-item';
    div.id = 'questao-' + questaoCount;

    div.innerHTML = `
      <div class="q-numero">${questaoCount}</div>

      <div class="q-tipo">
        <select class="na-input-sm" name="q_tipo_${questaoCount}">
          ${tiposQuestao.map(t => `<option value="${t}">${t}</option>`).join('')}
        </select>
      </div>

      <div class="q-pontos">
        <input
          type="number"
          name="q_pontos_${questaoCount}"
          value="10"
          class="na-input-sm q-pontos-input"
          min="1"
          max="100"
          onchange="atualizarPontos()"
        >
        <span>pts</span>
      </div>

      <div class="q-enunciado">
        <input
          type="text"
          name="q_enunciado_${questaoCount}"
          class="na-input-sm"
          placeholder="Digite o enunciado da questão..."
        >
      </div>

      <div class="q-tags">
        <span class="q-tag-alt">--</span>
      </div>

      <div class="q-acoes">
        <button type="button" onclick="removerQuestao(${questaoCount})" class="q-btn-del" title="Excluir questão">
          <i data-lucide="trash-2"></i>
        </button>
      </div>
    `;

    list.appendChild(div);
    atualizarPontos();
    lucide.createIcons();
  }

  function removerQuestao(id) {
    document.getElementById('questao-' + id)?.remove();
    atualizarPontos();
  }

  function atualizarPontos() {
    let total = 0;

    document.querySelectorAll('[name^="q_pontos_"]').forEach(el => {
      total += parseInt(el.value) || 0;
    });

    const pontosTotal = document.getElementById('pontosTotal');
    const recompensaPts = document.getElementById('recompensaPts');

    if (pontosTotal) pontosTotal.value = total;
    if (recompensaPts) recompensaPts.textContent = total + ' pts';
  }

  let bnccList = [];

  function adicionarBNCC() {
    const input = document.getElementById('bnccInput');
    const val = input.value.trim().toUpperCase();

    if (!val || bnccList.includes(val)) {
      input.value = '';
      return;
    }

    bnccList.push(val);
    renderBNCC();
    input.value = '';
  }

  function removerBNCC(tag) {
    bnccList = bnccList.filter(b => b !== tag);
    renderBNCC();
  }

  function renderBNCC() {
    const container = document.getElementById('bnccTags');

    container.innerHTML = bnccList.map(t =>
      `<span class="bncc-tag">
        ${t}
        <button type="button" onclick="removerBNCC('${t}')" class="bncc-remove">
          <i data-lucide="x"></i>
        </button>
      </span>`
    ).join('');

    document.getElementById('bnccHidden').value = bnccList.join(',');
    lucide.createIcons();
  }

  document.addEventListener('DOMContentLoaded', function() {
    const hidden = document.getElementById('bnccHidden');

    if (hidden && hidden.value.trim() !== '') {
      bnccList = hidden.value.split(',').map(item => item.trim()).filter(Boolean);
      renderBNCC();
    }

    alternarTipoHistoria();
    lucide.createIcons();
  });
</script>

<%- include('partials/footer.ejs') %>